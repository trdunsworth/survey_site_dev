    {
      "title": "Welcome",
      "questions": [
        {
          "id": 0,
          "text": "Thank you for participating in the NENA 2024 PSAP Survey. We know that your time is valuable and we appreciate you sharing your data with us. The information you share will help NENA better understand staffing and call processing realities throughout the industry and support meaningful solutions, advocacy, and future planning for the 9-1-1 community.\n\nThe survey will take approximately 30-45 minutes and consists of 99 question. Your voice matters, and your participation makes a difference.",
          "options": [],
          "type": "info"
        }
      ]
    },
